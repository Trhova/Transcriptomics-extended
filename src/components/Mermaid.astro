---
const { chart, title } = Astro.props as { chart: string; title: string };
---

<div class="not-prose my-8 rounded-[1.75rem] border border-white/10 bg-ink-950/70 p-5 shadow-panel">
  <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-accent-300">{title}</p>
  <pre data-mermaid-root class="mermaid !m-0 !overflow-x-auto !border-none !bg-transparent !p-0">{chart}</pre>
  <div class="mt-4 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm leading-7 text-ink-200">
    <slot />
  </div>
</div>

<script>
  import mermaid from "mermaid";

  mermaid.initialize({
    startOnLoad: false,
    theme: "base",
    securityLevel: "loose",
    themeVariables: {
      background: "#06111a",
      primaryColor: "#0c1721",
      primaryTextColor: "#edf5f8",
      primaryBorderColor: "#7dd3c3",
      lineColor: "#9ab9c8",
      secondaryColor: "#132332",
      tertiaryColor: "#173246"
    },
    flowchart: {
      useMaxWidth: true,
      curve: "basis"
    }
  });

  const nodes = document.querySelectorAll<HTMLElement>("[data-mermaid-root]:not([data-rendered])");
  for (const node of nodes) {
    await mermaid.run({ nodes: [node] });
    node.dataset.rendered = "true";
  }
</script>
