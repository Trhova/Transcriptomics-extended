---
import "../styles/global.css";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

const { title, description, tags = [], headings = [] } = Astro.props as {
  title: string;
  description: string;
  tags?: string[];
  headings?: Heading[];
};

const toc = headings.filter((heading) => heading.depth <= 3);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="relative min-h-screen overflow-x-hidden">
      <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <header class="panel mb-8 overflow-hidden px-6 py-8 sm:px-8 sm:py-10">
          <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-3xl space-y-4">
              <span class="eyebrow">Bulk RNA-seq handbook</span>
              <h1 class="font-display text-4xl tracking-tight text-white sm:text-5xl">{title}</h1>
              <p class="max-w-2xl text-base leading-7 text-ink-200 sm:text-lg">{description}</p>
            </div>
            <div class="flex max-w-xl flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm text-ink-200">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </header>

        <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_18rem]">
          <main class="panel min-w-0 px-5 py-8 sm:px-8">
            <div class="mb-8 rounded-2xl border border-white/10 bg-ink-950/70 p-5">
              <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-accent-300">Full table of contents</p>
              <nav aria-label="Page table of contents">
                <ol class="grid gap-2 text-sm text-ink-200 sm:grid-cols-2">
                  {toc.map((item) => (
                    <li class={item.depth === 3 ? "sm:pl-4" : ""}>
                      <a href={`#${item.slug}`}>{item.text}</a>
                    </li>
                  ))}
                </ol>
              </nav>
            </div>
            <article class="guide-prose">
              <slot />
            </article>
          </main>

          <aside class="hidden lg:block">
            <div class="panel sticky top-6 px-5 py-6">
              <p class="mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-accent-300">On this page</p>
              <nav aria-label="Secondary table of contents">
                <ol class="space-y-3 text-sm text-ink-200">
                  {toc.map((item) => (
                    <li class={item.depth === 3 ? "pl-4 text-ink-300" : ""}>
                      <a href={`#${item.slug}`}>{item.text}</a>
                    </li>
                  ))}
                </ol>
              </nav>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </body>
</html>
